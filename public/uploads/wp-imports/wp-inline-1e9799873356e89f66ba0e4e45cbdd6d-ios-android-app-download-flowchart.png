    <span id="hlb-count">...</span>
    <span class="hlb-text">people browsing right now</span>
  </span>
  <span class="hlb-divider"></span>
  <span class="hlb-item hlb-date">
    <span class="hlb-icon">📅</span>
    <span id="hlb-date"></span>
  </span>
</div>

<style>
#homepage-live-bar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 10px 18px;
    margin: 0 0 20px 0;
    background: #fff5f5;
    border: 1px solid rgba(229,57,53,0.2);
    border-left: 3px solid #e53935;
    border-radius: 6px;
    font-size: 13px;
    font-family: inherit;
    flex-wrap: wrap;
    width: fit-content;
}

.hlb-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #444;
  font-weight: 500;
}

.hlb-icon { font-size: 14px; }

#hlb-time {
  font-weight: 700;
  color: #e53935;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.03em;
}

#hlb-date {
  font-weight: 600;
  color: #555;
}

#hlb-count {
  font-weight: 800;
  font-size: 15px;
  color: #e53935;
  font-variant-numeric: tabular-nums;
  min-width: 16px;
  text-align: center;
  display: inline-block;
}

.hlb-text { color: #555; }

.hlb-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #e53935;
  flex-shrink: 0;
  animation: hlb-blink 1.6s ease-in-out infinite;
}

.hlb-divider {
  width: 1px;
  height: 16px;
  background: rgba(229,57,53,0.25);
  display: inline-block;
}

.hlb-pop {
  animation: hlb-pop 0.3s ease-out forwards;
}

@keyframes hlb-blink {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.2; transform: scale(0.55); }
}

@keyframes hlb-pop {
  0%   { transform: scale(1); color: #e53935; }
  50%  { transform: scale(1.5); color: #b71c1c; }
  100% { transform: scale(1); color: #e53935; }
}

@keyframes hlb-glow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(229,57,53,0); }
  50%       { box-shadow: 0 0 0 4px rgba(229,57,53,0.12); }
}

#homepage-live-bar {
  animation: hlb-glow 2.8s ease-in-out infinite;
}
</style>

<script>
(function() {
  function formatTime(d) {
    let h = d.getHours(), m = d.getMinutes(), s = d.getSeconds();
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
    return h + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0') + ' ' + ampm;
  }

  function formatDate(d) {
    const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return days[d.getDay()] + ', ' + months[d.getMonth()] + ' ' + d.getDate() + ' ' + d.getFullYear();
  }

  function init() {
    const timeEl  = document.getElementById('hlb-time');
    const countEl = document.getElementById('hlb-count');
    const dateEl  = document.getElementById('hlb-date');

    if (!timeEl || !countEl || !dateEl) return;

    // Date (static)
    dateEl.textContent = formatDate(new Date());

    // Clock
    function tick() { timeEl.textContent = formatTime(new Date()); }
    tick();
    setInterval(tick, 1000);

    // Viewers
    let viewers = Math.floor(Math.random() * 10) + 8;
    countEl.textContent = viewers;

    function drift() {
      viewers = Math.max(5, Math.min(25, viewers + (Math.random() < 0.5 ? -1 : 1)));
      countEl.textContent = viewers;
      countEl.classList.remove('hlb-pop');
      void countEl.offsetWidth;
      countEl.classList.add('hlb-pop');
      setTimeout(drift, 6000 + Math.random() * 8000);
    }
    setTimeout(drift, 6000 + Math.random() * 8000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>				</div>
