		<style type="text/css" id="wp-custom-css">
			/* ═══════════════════════════
   GOOGLE FONTS — sirf ek baar
═══════════════════════════ */
@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@100;200;300;400;500;600;700;800;900&family=Nunito:wght@400;500;600&display=swap');

/* ═══════════════════════════
   CSS VARIABLES
═══════════════════════════ */
:root {
  --font-head: 'Montserrat', sans-serif;
  --font-body: 'Nunito', sans-serif;
}

/* ═══════════════════════════
   TYPOGRAPHY — POST CONTENT
═══════════════════════════ */
.the-post-header .post-meta .post-title,
.post-content h1, .post-content h2,
.post-content h3, .post-content h4,
.post-content h5, .post-content h6,
.wp-block-heading {
  font-family: 'Montserrat', sans-serif !important;
}

.the-post-header .post-meta .post-title {
  font-size: 36px !important;
  font-weight: 600 !important;
  color: #000 !important;
  letter-spacing: 0.01px !important;
}

.entry-content {
  max-width: 740px;
  margin: auto;
}

.entry-content p,
.entry-content li {
  font-family: 'Nunito', sans-serif !important;
  font-size: 20px !important;
  line-height: 1.9;
  color: #333;
  margin-bottom: 22px;
}

.entry-content h2 {
  font-size: 36px;
  margin-top: 40px;
  margin-bottom: 15px;
  font-weight: 700;
}

.entry-content h2 strong { font-weight: 900 !important; }

.entry-content h3 {
  font-size: 28px;
  margin-top: 30px;
  margin-bottom: 10px;
}

@media (max-width: 768px) {
  .entry-content p { font-size: 19px !important; }
  p { font-size: 17px !important; }
}

/* ═══════════════════════════
   FLUENT FORM — SINGLE SET
   (FF_ID replace karo apne actual form ID se, e.g. fluent_form_3)
═══════════════════════════ */
.fluentform,
.fluent_form_FF_ID {
  max-width: 700px;
  margin: 15px auto;
  padding: 40px;
  background: #fff;
  border-radius: 14px;
  border: 1px solid #eee;
  box-shadow: 0 20px 40px rgba(0,0,0,0.08);
}

.fluentform label,
.fluent_form_FF_ID .ff-el-input--label label {
  font-weight: 600;
  color: #2d3436;
  margin-bottom: 6px;
  display: block;
  font-size: 15px;
}

.fluentform .ff-el-form-control,
.fluent_form_FF_ID .ff-el-form-control {
  width: 100%;
  padding: 14px 16px;
  margin-bottom: 18px;
  border: 1.5px solid #e6e6e6;
  border-radius: 8px;
  box-sizing: border-box;
  font-size: 15px;
  color: #333;
  background: #fafafa;
  transition: all .25s ease;
}

.fluentform .ff-el-form-control::placeholder,
.fluent_form_FF_ID .ff-el-form-control::placeholder { color: #a0a0a0; }

.fluentform .ff-el-form-control:focus,
.fluent_form_FF_ID .ff-el-form-control:focus {
  border-color: #e63946;
  background: #fff;
  outline: none;
  box-shadow: 0 0 0 4px rgba(230,57,70,0.12);
}

.fluentform textarea,
.fluent_form_FF_ID textarea.ff-el-form-control {
  height: 130px;
  resize: vertical;
}

.fluentform .ff-btn-submit,
.fluent_form_FF_ID .ff-btn-submit {
  width: 100%;
  padding: 16px;
  border: none;
  border-radius: 8px;
  background: #e63946;
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  margin-top: 15px;
  box-shadow: 0 8px 20px rgba(230,57,70,.3);
  transition: all .25s ease;
}

.fluentform .ff-btn-submit:hover,
.fluent_form_FF_ID .ff-btn-submit:hover {
  background: #d62828;
  transform: translateY(-2px);
  box-shadow: 0 12px 30px rgba(230,57,70,.35);
}

.fluentform .ff-el-group,
.fluent_form_FF_ID .ff-el-group { margin-bottom: 12px; }

.fluent_form_FF_ID .ff-el-is-required label::after {
  content: " *";
  color: #e63946;
}

.fluent_form_FF_ID .ff-el-is-error .error {
  color: #e63946;
  font-size: 14px;
  margin-top: 5px;
}

/* Specific form overrides */
.fluent_form_3 .ff-btn-submit,
.fluent_form_5 .ff-btn-submit { padding: 0 15px !important; }

form.fluent_form_2 .ff-btn-submit:not(.ff_btn_no_style) {
  background-color: #de3333 !important;
  color: #fff;
}

.elementor-8994 .elementor-element-99bd5c8 .ff-btn-submit,
.elementor-8986 .elementor-element-99bd5c8 .ff-btn-submit {
  background-color: #ff0100 !important;
  color: #fff !important;
}

@media (max-width: 600px) {
  .fluentform,
  .fluent_form_FF_ID { padding: 20px; margin: 15px 0; }
  .fluentform .ff-el-form-control,
  .fluent_form_FF_ID .ff-el-form-control { font-size: 14px; }
}

/* Footer form reset */
.footernewlatter .fluentform,
.main-sidebar .spc-newsletter .fluentform {
  max-width: max-content;
  margin: 0;
  padding: 0;
  background: unset;
  border: none;
  box-shadow: none;
  border-radius: 0;
}

.footernewlatter span { color: #fff; }
.footernewlatter span a { color: red; }

/* ═══════════════════════════
   LIVE INFO BAR
═══════════════════════════ */
#live-info-bar {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 10px 16px;
  margin: 0 0 24px;
  background: #fff5f5;
  border: 1px solid rgba(229,57,53,0.2);
  border-left: 3px solid #e53935;
  border-radius: 6px;
  font-size: 13px;
  flex-wrap: wrap;
  width: fit-content;
}

.lib-clock {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #444;
  font-weight: 500;
}

.lib-clock-icon { font-size: 14px; }

#lib-time {
  font-weight: 700;
  font-size: 16px;
  color: #e53935;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.03em;
}

.lib-divider {
  width: 1px;
  height: 16px;
  background: rgba(229,57,53,0.25);
  display: inline-block;
}

.lib-viewers {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 16px;
  font-weight: 500;
  color: #444;
}

.lib-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #e53935;
  flex-shrink: 0;
  animation: lib-blink 1.6s ease-in-out infinite;
}

#lib-count {
  font-weight: 800;
  font-size: 18px;
  color: #e53935;
  font-variant-numeric: tabular-nums;
  min-width: 16px;
  text-align: center;
  display: inline-block;
}

@keyframes lib-blink {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.2; transform: scale(0.55); }
}

.lib-pop { animation: lib-pop 0.3s ease-out forwards; }

@keyframes lib-pop {
  0%   { transform: scale(1); color: #e53935; }
  50%  { transform: scale(1.5); color: #b71c1c; }
  100% { transform: scale(1); color: #e53935; }
}

span.has-next-icon.meta-item.comments.has-icon { display: none; }
span.live-viewers-inject { display: none; }

/* ═══════════════════════════
   SIDEBAR FIXED BUTTONS
═══════════════════════════ */
#submit-post-btn,
#feedback-btn {
  position: fixed;
  right: 0;
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
  writing-mode: vertical-lr;
  width: 44px;
  color: #fff;
  font-family: 'Segoe UI', Arial, sans-serif;
  font-weight: 600;
  font-size: 15px;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  text-decoration: none;
  white-space: nowrap;
  border-radius: 10px 0 0 10px;
  cursor: pointer;
  transition: width .25s ease, transform .25s ease, box-shadow .25s ease, background .25s ease;
}

#submit-post-btn {
  bottom: 305px;
  padding: 28px 12px;
  background: #D91E2A;
  box-shadow: -4px 0 20px rgba(217,30,42,0.65), -2px 0 8px rgba(217,30,42,0.40);
  animation: sidePulse 3s ease-in-out infinite 0.8s;
}

#submit-post-btn:hover {
  width: 54px;
  transform: translateX(-6px);
  background: #b8151f;
  animation-play-state: paused;
}

#feedback-btn {
  bottom: 160px;
  padding: 22px 12px;
  background: #D91E2A;
  box-shadow: -3px 0 14px rgba(0,0,0,0.55), -1px 0 5px rgba(0,0,0,0.35);
}

#feedback-btn:hover {
  width: 52px;
  transform: translateX(-5px);
  box-shadow: -6px 0 24px rgba(217,30,42,0.70);
}

@keyframes sidePulse {
  0%, 100% { box-shadow: -4px 0 20px rgba(217,30,42,0.65), -2px 0 8px rgba(217,30,42,0.40); }
  50%       { box-shadow: -9px 0 42px rgba(217,30,42,1.00), -4px 0 18px rgba(217,30,42,0.80); }
}

@media (max-width: 600px) {
  #submit-post-btn, #feedback-btn { font-size: 13px; width: 36px; letter-spacing: 0.07em; }
  #submit-post-btn { bottom: 260px; padding: 22px 9px; }
  #feedback-btn    { bottom: 130px; padding: 18px 9px; }
}

/* ═══════════════════════════
   LAYOUT & MISC
═══════════════════════════ */
.alhp-wrap { margin: 0 !important; }
.alhp-core-body p {
  margin: 0 0 10px;
  font-family: "Source Sans 3", system-ui, -apple-system, "Segoe UI", Arial, sans-serif !important;
}

.alhp-sec-lbl  { font-size: 38px; font-weight: 800; }
.alhp-core-h2  { font-size: 28px; }
.alhp-core-num { font-size: 20px; font-weight: 800; padding: 14px; }
.alhp-h1       { font-size: clamp(32px, 5vw, 56px) !important; }

.alhp-btn-outline-w,
.alhp-btn-ghost-w {
  background: #16A34A !important;
  color: #fff;
  border-color: transparent !important;
}

.alhp-btn-outline-w:hover,
.alhp-btn-ghost-w:hover { background: #22C55E !important; }

.alhp-cta {
  overflow: hidden;
  padding: 80px 0;
  margin: 0 auto;
  display: flex;
  justify-content: center;
}

.al2-footer-col-title { font-size: 19px; }
.al2-footer-links a   { font-size: 16px; }
.al2-footer-nl-sub    { font-size: 16px; }
.al2-footer-logo      { font-size: 32px; }
.al-card-title        { font-size: 21px; }
.al-card-excerpt      { font-size: 16px; line-height: 1.25; }

.ft-bottom {
  padding: 20px 36px;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.ft-nav-link { color: #fff; }
div#nav_menu-3 li a { font-size: 17px; font-weight: 600; }

.feat-grid .item { margin-bottom: 35px; }
.feat-grid .l-post { margin-bottom: 25px; }
.feat-grid .media { border-radius: 12px; overflow: hidden; }

.code-block.code-block-1 { margin-top: 16px !important; }

.time-homepg { display: flex; justify-content: center; }

.disabled-option {
  opacity: 0.4;
  pointer-events: none;
  transition: 0.3s ease;
}
.disabled-option .ff_plan_title { color: #999 !important; }
.disabled-option input { cursor: not-allowed; }

/* ═══════════════════════════
   NEWSLETTER WIDGETS
═══════════════════════════ */
.appluxe-newsletter-wrap {
  display: none;
  background: #0a0a0a !important;
  border: 1px solid rgba(255,255,255,0.08) !important;
  border-radius: 14px !important;
  padding: 26px 30px !important;
  margin: 28px 0 !important;
  gap: 28px !important;
  align-items: center !important;
  box-shadow: 0 4px 20px rgba(0,0,0,0.15) !important;
}

@media (max-width: 768px) {
  .appluxe-newsletter-wrap { display: flex !important; flex-direction: column !important; padding: 20px 18px !important; }
  .appluxe-newsletter-wrap .appluxe-form { width: 100% !important; }
  .alhp-svc-grid, .alhp-blog-grid, .alhp-kt-grid { grid-template-columns: 1fr !important; }
  .alhp-faq-q { font-size: 12px !important; line-height: 1.2; }
}

@media (min-width: 641px) {
  .appluxe-newsletter-wrap { display: flex !important; }
  .appluxe-newsletter-wrap .appluxe-form { width: 240px !important; flex-shrink: 0 !important; }
}

.appluxe-newsletter-wrap .appluxe-nl-text h4 {
  color: #fff !important; font-size: 18px !important; font-weight: 700 !important; margin: 0 0 8px !important;
}
.appluxe-newsletter-wrap .appluxe-nl-text p {
  color: #fff !important; font-size: 13px !important; margin: 0 !important;
}

/* Shared form */
.appluxe-form {
  background: transparent !important;
  padding: 0 !important;
  border: none !important;
  margin: 0 !important;
}
.appluxe-form input[type="email"] {
  width: 100% !important; padding: 11px 14px !important; border-radius: 8px !important;
  border: none !important; background: #fff !important; color: #111 !important;
  font-size: 13px !important; box-sizing: border-box !important; margin-bottom: 10px !important;
  outline: none !important;
}
.appluxe-form input[type="email"]::placeholder { color: #999 !important; }
.appluxe-form input[type="email"]:focus { box-shadow: 0 0 0 2px rgba(200,0,0,0.4) !important; }
.appluxe-form .appluxe-consent {
  font-size: 11px !important; color: #fff !important; display: flex !important;
  gap: 7px !important; align-items: flex-start !important; margin-bottom: 12px !important;
  line-height: 1.55 !important; cursor: pointer !important;
}
.appluxe-form .appluxe-consent input[type="checkbox"] {
  margin-top: 2px !important; flex-shrink: 0 !important; width: auto !important; accent-color: #ff0100 !important;
}
.appluxe-form .appluxe-consent a { color: #fff !important; text-decoration: underline !important; }
.appluxe-form button[type="submit"] {
  width: 100% !important; padding: 0 !important; border: none !important; border-radius: 8px !important;
  background: #ff0000 !important; color: #fff !important; font-weight: 700 !important;
  font-size: 13px !important; letter-spacing: 1px !important; cursor: pointer !important;
  text-transform: uppercase !important;
}
.appluxe-form button[type="submit"]:hover { opacity: 0.9 !important; }

/* Sidebar newsletter block */
#smartmag-block-newsletter-4 {
  background: #0a0a0a !important;
  border: 1px solid rgba(255,255,255,0.08) !important;
  box-shadow: 0 4px 24px rgba(0,0,0,0.25) !important;
  border-radius: 14px !important;
  padding: 5px !important;
  overflow: hidden !important;
}
#smartmag-block-newsletter-4 .widget-title {
  background: transparent !important; padding: 16px 18px 14px !important;
  border-bottom: 1px solid rgba(255,255,255,0.07) !important; margin: 0 !important;
}
#smartmag-block-newsletter-4 .widget-title .heading { color: #fff !important; margin: 0 !important; padding: 0 !important; }
#smartmag-block-newsletter-4 .block-head-ac::before, #smartmag-block-newsletter-4 .block-head-ac::after,
#smartmag-block-newsletter-4 .block-head::before, #smartmag-block-newsletter-4 .block-head::after,
#smartmag-block-newsletter-4 .has-style::before, #smartmag-block-newsletter-4 .has-style::after { display: none !important; }
#smartmag-block-newsletter-4 .block,
#smartmag-block-newsletter-4 .bg-wrap { padding: 0 !important; background: transparent !important; }
#smartmag-block-newsletter-4 .bg-wrap { display: none !important; }
#smartmag-block-newsletter-4 .spc-newsletter, #smartmag-block-newsletter-4 .spc-newsletter-b,
#smartmag-block-newsletter-4 .spc-newsletter-left, #smartmag-block-newsletter-4 .spc-newsletter-sm {
  background: transparent !important; border: none !important; padding: 16px 18px 20px !important; box-shadow: none !important;
}
#smartmag-block-newsletter-4 .inner { padding: 0 !important; }
#smartmag-block-newsletter-4 .spc-newsletter .heading { display: none !important; }
#smartmag-block-newsletter-4 .message p, #smartmag-block-newsletter-4 .base-text p {
  color: #fff !important; font-size: 15px !important; line-height: 1.65 !important; margin: 0 !important;
}

/* Exit popup */
#appluxe-exit-popup {
  position: fixed; inset: 0; background: rgba(0,0,0,0.85);
  backdrop-filter: blur(8px); display: none; justify-content: center;
  align-items: center; z-index: 99999;
}
.appluxe-popup-box {
  background: #0a0a0a; padding: 30px 32px; border-radius: 16px;
  max-width: 420px; width: 90%; color: #fff; position: relative;
  border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
#appluxe-close {
  position: absolute !important; top: 14px !important; right: 18px !important;
  cursor: pointer !important; font-size: 22px !important; color: #fff !important;
  line-height: 1 !important; font-weight: 300 !important;
}
#appluxe-close:hover { opacity: 0.7 !important; }
.appluxe-popup-box h3 { color: #fff !important; font-size: 20px !important; font-weight: 700 !important; margin: 0 0 8px !important; }
.appluxe-popup-box > p { color: #fff !important; font-size: 13px !important; margin: 0 0 16px !important; }
.appluxe-popup-box small {
  display: block !important; text-align: center !important; font-size: 10px !important;
  color: rgba(255,255,255,0.45) !important; margin-top: 10px !important; letter-spacing: 0.5px !important;
}

.main-sidebar .spc-newsletter-b { border: 0 !important; background: transparent !important; }
.main-sidebar .spc-newsletter .heading { margin-bottom: 0 !important; }





.spc-newsletter > .inner {
    
    border: 0px !important;
    
}



.alhp-blog-title a {
   
  
    font-size: 19px;
}


.alhp-blog-exc {
    font-size: 18px;
    
}


.alhp-blog-meta {
    font-size: 14px;
}


.alhp-blog-rm {
    font-size: 14px;
}

.alhp-blog-badge {
    
    font-size: 14px;
}


.alhp-blog-badge {
    position: absolute;
    top: 0px;
    left: 0px;
    padding: 4px 10px;
    border-radius: 5px 5px 0px 0pc;
    display: inline-flex;
}


.alhp-wrap {
    max-width: none !important;
}		</style>
		

</head>

